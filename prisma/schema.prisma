// Prisma schema stub — add your models below.
// See https://pris.ly/d/prisma-schema for syntax.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries through the PgBouncer pooler (transaction mode).
  url       = env("DATABASE_URL")
  // Migrations / `prisma db push` need a DIRECT Postgres connection — the
  // pooler can't run them. DIRECT_URL must be set (see .env.example); it's
  // only used by migrate/db push, never by the runtime client.
  directUrl = env("DIRECT_URL")
}

// Placeholder model — Prisma needs at least one model in the schema for
// `prisma generate` to produce a usable client. Delete this when you
// add your first real model.
model StarterMarker {
  id Int @id @default(autoincrement())

  @@map("_starter_marker")
}
