generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder model — Prisma needs at least one model in the schema for
// `prisma generate` to produce a usable client. Delete this when you
// add your first real model.
model StarterMarker {
  id Int @id @default(autoincrement())

  @@map("_starter_marker")
}
