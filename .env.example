# Copy to .env and fill in real values.

# Postgres connection. The homelab shared cluster runs PgBouncer on :5432
# in TRANSACTION pooling mode (Postgres itself is on localhost:5433 of the
# DB host, not LAN-reachable). So:
#   - Runtime queries go through the pooler → append `pgbouncer=true` so
#     Prisma disables prepared statements (required for transaction pooling).
#   - keep `connection_limit=3` so you don't exhaust the shared pool.
# As of #169 the pooler uses auth_query, so a new DB role works the moment
# it exists — no userlist edit needed.
# (quoted — the `&` would otherwise break any `set -a; . .env` shell sourcing)
DATABASE_URL="postgresql://__APP_DB__:CHANGE_ME@192.168.7.223:5432/__APP_DB__?pgbouncer=true&connection_limit=3"

# Migrations / `prisma db push` CANNOT run through the transaction pooler —
# Prisma's migration engine needs a direct Postgres connection (port 5433).
# DIRECT_URL is used by `prisma migrate`/`db push`; DATABASE_URL by runtime.
# NOTE: :5433 is LAN-open on the media cluster (.149) but localhost-only on
# the shared cluster (.223) — for .223, run `prisma db push` ON the DB host
# (or via an SSH tunnel). The entrypoint's db push is non-fatal, so a boot
# where 5433 is unreachable won't crash-loop the container.
DIRECT_URL="postgresql://__APP_DB__:CHANGE_ME@192.168.7.223:5433/__APP_DB__"

# Host port published by docker compose. Container always listens on 3000.
PORT=__APP_PORT__

# Pino log level — debug | info | warn | error
LOG_LEVEL=info

# UID/GID for the app user inside the container. Match host owner of
# ./data so Pawzitive can read the backup without running as root.
PUID=1000
PGID=1000

# Server timezone — keep America/Chicago so per-day stats align with
# the user's local day boundary.
TZ=America/Chicago
